# Create a bot with Telegram's @BotFather, then paste the token here.
TELEGRAM_BOT_TOKEN=123456:replace-me

# Optional but strongly recommended.
# Send /whoami to the bot once, then paste your numeric Telegram user ID here.
TELEGRAM_ALLOWED_USER_IDS=
AGENT_MODE=local
TELEGRAM_MODE=polling
PUBLIC_URL=
PORT=3000

# AI providers. Gemini is the default. OpenAI is optional for valuation upgrades.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=

# Keep Codex execution disabled until you are ready.
# /chrome works without this.
ENABLE_CODEX_EXEC=false

# Where Codex should run if /ask_codex is enabled.
CODEX_WORKSPACE=/Users/alvinlim/Desktop/Startup-Insight-AI/Automation

# Max runtime for a Codex request from Telegram.
CODEX_TIMEOUT_MS=120000

# Gmail read-only OAuth.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
GMAIL_TOKEN_PATH=.tokens/gmail-token.json
GOOGLE_OAUTH_TOKEN_JSON=
ALLOW_TOKEN_EXPORT=false

# Optional comma-separated RSS feeds for /morning headlines.
NEWS_RSS_FEEDS=
WATCHLIST=NVDA,MSFT,AAPL,AMZN,GOOGL,META,TSLA
WATCHLIST_PATH=.data/watchlist.json
WATCHLIST_VALUATION_ENABLED=false

# Daily automated Telegram morning digest.
DAILY_DIGEST_ENABLED=false
DAILY_DIGEST_TIME=08:00
DAILY_MARKET_DIGEST_ENABLED=false
MARKET_DIGEST_TIME=08:30
TIMEZONE=America/New_York

# Optional local valuation model runner.
VALUATION_MODEL_PATH=models/valuation/runner.py
PYTHON_BIN=python3
MODEL_RUNNER_MODE=disabled
VALUATION_TIMEOUT_MS=30000
